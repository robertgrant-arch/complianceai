// ComplianceAI Prisma Schema
// PostgreSQL database schema for the compliance auditing platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserRole {
  ADMIN
  SUPERVISOR
  AUDITOR
  VIEWER
}

enum CallStatus {
  PENDING
  TRANSCRIBING
  ANALYZING
  COMPLETED
  ERROR
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum RecommendedAction {
  NONE
  COACHING
  REVIEW
  ESCALATE
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FlagType {
  CRITICAL
  WARNING
  INFO
}

enum FlagCategory {
  COMPLIANCE
  TONE
  KEYWORD
  QUALITY
  REQUIRED
  RISK
  COMPETITOR
}

enum KeywordListType {
  PROHIBITED
  REQUIRED
  RISK
  COMPETITOR
}

enum CoachingTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum ScorecardType {
  COMPLIANCE
  SALES
  SUPPORT
}

enum ScorecardItemType {
  BOOLEAN
  SCALE
}

enum ConsentChannel {
  VOICE
  SMS
  EMAIL
  WEB
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// --- Models ---

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  password         String
  role             UserRole  @default(VIEWER)
  isActive         Boolean   @default(true)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  auditLogs        AuditLog[]
  coachingTasks    CoachingTask[]
  qaOverrides      QAOverride[]
  @@map("users")
}

model CallRecord {
  id            String        @id @default(cuid())
  five9CallId   String        @unique
  agentId       String
  agentName     String
  campaignName  String
  leadSource    String?
  state         String?
  callDirection CallDirection @default(OUTBOUND)
  ani           String?
  dnis          String?
  startTime     DateTime
  endTime       DateTime?
  duration      Int?
  disposition   String?
  s3Key         String?
  status        CallStatus    @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transcript    CallTranscript?
  auditResult   AuditResult?
  consentEvents ConsentEvent[]
  coachingTasks CoachingTask[]
  @@index([agentId])
  @@index([status])
  @@index([startTime])
  @@index([campaignName])
  @@index([agentId, startTime])
  @@map("call_records")
}

model CallTranscript {
  id              String      @id @default(cuid())
  callRecordId    String      @unique
  fullText        String      @db.Text
  segments        Json
  wordCount       Int         @default(0)
  language        String      @default("en")
  durationSeconds Float?
  createdAt       DateTime    @default(now())
  callRecord      CallRecord  @relation(fields: [callRecordId], references: [id], onDelete: Cascade)
  @@map("call_transcripts")
}

model AuditResult {
  id               String            @id @default(cuid())
  callRecordId     String            @unique
  overallScore     Int
  complianceScore  Int
  toneScore        Int
  qualityScore     Int
  summary          String            @db.Text
  recommendedAction RecommendedAction @default(NONE)
  sentimentAgent   Sentiment         @default(NEUTRAL)
  sentimentCustomer Sentiment        @default(NEUTRAL)
  topicsDiscussed  Json              @default("[]")
  callOutcome      String?
  aiModel          String            @default("claude-3-5-sonnet")
  createdAt        DateTime          @default(now())
  callRecord       CallRecord        @relation(fields: [callRecordId], references: [id], onDelete: Cascade)
  auditFlags       AuditFlag[]
  qaOverrides      QAOverride[]
  scorecardResults ScorecardResult[]
  @@map("audit_results")
}

model AuditFlag {
  id            String       @id @default(cuid())
  auditResultId String
  type          FlagType
  category      FlagCategory
  description   String
  timestamp     Float?
  keyword       String?
  quote         String?      @db.Text
  createdAt     DateTime     @default(now())
  auditResult   AuditResult  @relation(fields: [auditResultId], references: [id], onDelete: Cascade)
  @@index([auditResultId])
  @@index([type])
  @@index([auditResultId, type])
  @@map("audit_flags")
}

model KeywordList {
  id          String          @id @default(cuid())
  name        String
  description String?
  type        KeywordListType
  isActive    Boolean         @default(true)
  keywords    Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@map("keyword_lists")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("system_settings")
}

model RetentionPolicy {
  id           String   @id @default(cuid())
  callStatus   String
  retainDays   Int
  deleteAudio  Boolean  @default(true)
  deleteRecord Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([callStatus])
  @@map("retention_policies")
}

model Settings {
  id               String   @id @default("singleton")
  five9Hostname    String?
  five9Username    String?
  five9Password    String?  @db.Text
  openAiKey        String?  @db.Text
  slackWebhookUrl  String?  @db.Text
  slackChannel     String?
  notifyOnScore    Boolean  @default(false)
  scoreThreshold   Int      @default(70)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@map("settings")
}

// --- New: DNC List ---
model DncEntry {
  id          String   @id @default(cuid())
  phone       String   @unique
  source      String   @default("internal")
  addedBy     String?
  reason      String?
  createdAt   DateTime @default(now())
  @@index([phone])
  @@map("dnc_entries")
}

// --- New: Consent Events ---
model ConsentEvent {
  id           String        @id @default(cuid())
  callRecordId String?
  phone        String
  agentId      String
  channel      ConsentChannel @default(VOICE)
  consentGiven Boolean
  wording      String?       @db.Text
  state        String?
  campaignId   String?
  recordedAt   DateTime      @default(now())
  callRecord   CallRecord?   @relation(fields: [callRecordId], references: [id], onDelete: SetNull)
  @@index([phone])
  @@index([agentId])
  @@map("consent_events")
}

// --- New: Pre-dial Check Log ---
model PreDialCheck {
  id          String   @id @default(cuid())
  phone       String
  agentId     String?
  campaignId  String?
  leadSource  String?
  state       String?
  allowed     Boolean
  violations  Json     @default("[]")
  checkedAt   DateTime @default(now())
  @@index([phone])
  @@index([checkedAt])
  @@map("pre_dial_checks")
}

// --- New: Scorecards ---
model Scorecard {
  id        String        @id @default(cuid())
  name      String
  type      ScorecardType
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     ScorecardItem[]
  results   ScorecardResult[]
  campaigns ScorecardCampaign[]
  @@map("scorecards")
}

model ScorecardItem {
  id             String            @id @default(cuid())
  scorecardId    String
  code           String
  description    String
  category       String
  weight         Float             @default(1.0)
  evaluationType ScorecardItemType @default(BOOLEAN)
  maxScore       Float             @default(1.0)
  createdAt      DateTime          @default(now())
  scorecard      Scorecard         @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  @@index([scorecardId])
  @@map("scorecard_items")
}

model ScorecardCampaign {
  id          String    @id @default(cuid())
  scorecardId String
  campaignName String
  scorecard   Scorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  @@unique([scorecardId, campaignName])
  @@map("scorecard_campaigns")
}

model ScorecardResult {
  id            String      @id @default(cuid())
  auditResultId String
  scorecardId   String
  score         Float
  itemScores    Json        @default("[]")
  createdAt     DateTime    @default(now())
  auditResult   AuditResult @relation(fields: [auditResultId], references: [id], onDelete: Cascade)
  scorecard     Scorecard   @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  @@index([auditResultId])
  @@map("scorecard_results")
}

// --- New: QA Overrides (manual QA) ---
model QAOverride {
  id            String      @id @default(cuid())
  auditResultId String
  userId        String
  overallScore  Int?
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())
  auditResult   AuditResult @relation(fields: [auditResultId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([auditResultId])
  @@map("qa_overrides")
}

// --- New: Coaching Tasks ---
model CoachingTask {
  id           String              @id @default(cuid())
  agentId      String
  callRecordId String?
  ruleCode     String?
  title        String
  description  String?             @db.Text
  status       CoachingTaskStatus  @default(OPEN)
  assignedToId String?
  dueAt        DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  callRecord   CallRecord?         @relation(fields: [callRecordId], references: [id], onDelete: SetNull)
  assignedTo   User?               @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  @@index([agentId])
  @@index([status])
  @@map("coaching_tasks")
}

// --- New: Export Cases ---
model ExportCase {
  id          String       @id @default(cuid())
  label       String?
  callIds     Json         @default("[]")
  status      ExportStatus @default(PENDING)
  downloadUrl String?
  requestedBy String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@map("export_cases")
}

// --- New: Real-time Alert Rules ---
model AlertRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  pattern     String
  severity    FlagType @default(WARNING)
  isActive    Boolean  @default(true)
  campaigns   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("alert_rules")
}
