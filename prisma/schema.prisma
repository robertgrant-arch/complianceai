// ComplianceAI Prisma Schema
// PostgreSQL database schema for the compliance auditing platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (C-06) ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SUPERVISOR
  AUDITOR
  VIEWER
}

/// C-06: Replaces String status field on CallRecord
enum CallStatus {
  PENDING
  TRANSCRIBING
  ANALYZING
  COMPLETED
  ERROR
}

/// C-06: Replaces String callDirection field on CallRecord
enum CallDirection {
  INBOUND
  OUTBOUND
}

/// C-06: Replaces String recommendedAction field on AuditResult
enum RecommendedAction {
  NONE
  COACHING
  REVIEW
  ESCALATE
}

/// C-06: Replaces String sentimentAgent / sentimentCustomer fields
enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// C-06: Replaces String type field on AuditFlag
enum FlagType {
  CRITICAL
  WARNING
  INFO
}

/// C-06: Replaces String category field on AuditFlag
enum FlagCategory {
  COMPLIANCE
  TONE
  KEYWORD
  QUALITY
  REQUIRED
  RISK
  COMPETITOR
}

/// C-06 / H-01: Replaces String type field on KeywordList
enum KeywordListType {
  PROHIBITED
  REQUIRED
  RISK
  COMPETITOR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // bcrypt hash, minimum 12 rounds (C-02)
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("users")
}

model CallRecord {
  id            String        @id @default(cuid())
  five9CallId   String        @unique
  agentId       String
  agentName     String
  campaignName  String
  callDirection CallDirection @default(OUTBOUND) // C-06
  ani           String?
  dnis          String?
  startTime     DateTime
  endTime       DateTime?
  duration      Int?          // seconds
  disposition   String?
  s3Key         String?       // S3/MinIO key for audio file
  status        CallStatus    @default(PENDING) // C-06
  reviewedBy    String?
  reviewedAt    DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transcript  CallTranscript?
  auditResult AuditResult?

  @@index([agentId])
  @@index([status])
  @@index([startTime])
  @@index([campaignName])
  @@index([agentId, startTime]) // M-07: composite index for agent scorecard queries
  @@map("call_records")
}

model CallTranscript {
  id              String   @id @default(cuid())
  callRecordId    String   @unique
  fullText        String   @db.Text
  segments        Json     // Array of TranscriptSegment {speaker, startTime, endTime, text}
  wordCount       Int      @default(0)
  language        String   @default("en")
  durationSeconds Float?
  createdAt       DateTime @default(now())

  callRecord CallRecord @relation(fields: [callRecordId], references: [id], onDelete: Cascade)

  @@map("call_transcripts")
}

model AuditResult {
  id                String            @id @default(cuid())
  callRecordId      String            @unique
  overallScore      Int               // 0-100
  complianceScore   Int               // 0-100
  toneScore         Int               // 0-100
  qualityScore      Int               // 0-100
  summary           String            @db.Text
  recommendedAction RecommendedAction @default(NONE) // C-06
  sentimentAgent    Sentiment         @default(NEUTRAL) // C-06
  sentimentCustomer Sentiment         @default(NEUTRAL) // C-06
  topicsDiscussed   Json              @default("[]")
  callOutcome       String?
  aiModel           String            @default("gpt-4o")
  createdAt         DateTime          @default(now())

  callRecord CallRecord  @relation(fields: [callRecordId], references: [id], onDelete: Cascade)
  auditFlags AuditFlag[]

  @@map("audit_results")
}

model AuditFlag {
  id            String       @id @default(cuid())
  auditResultId String
  type          FlagType     // C-06
  category      FlagCategory // C-06
  description   String
  timestamp     Float?       // seconds into the call
  keyword       String?
  quote         String?      @db.Text
  createdAt     DateTime     @default(now())

  auditResult AuditResult @relation(fields: [auditResultId], references: [id], onDelete: Cascade)

  @@index([auditResultId])
  @@index([type])
  @@index([auditResultId, type]) // M-07: composite index for flag queries
  @@map("audit_flags")
}

/// H-01: Keywords stored as JSON array [{word, isCaseSensitive, isRegex}]
/// Eliminates the separate Keyword table and join overhead.
model KeywordList {
  id          String          @id @default(cuid())
  name        String
  description String?
  type        KeywordListType // C-06 / H-01
  isActive    Boolean         @default(true)
  keywords    Json            @default("[]") // H-01: KeywordItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("keyword_lists")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

/// H-09: Retention policy per call status type
model RetentionPolicy {
  id           String   @id @default(cuid())
  callStatus   String   // matches CallStatus enum values as strings
  retainDays   Int
  deleteAudio  Boolean  @default(true)
  deleteRecord Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([callStatus])
  @@map("retention_policies")
}
