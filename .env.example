# =============================================================================
# ComplianceAI Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Database
DATABASE_URL="postgresql://complianceai:complianceai_secret@localhost:5432/complianceai"
POSTGRES_USER=complianceai
POSTGRES_PASSWORD=complianceai_secret
POSTGRES_DB=complianceai

# Redis
REDIS_URL="redis://:redis_secret@localhost:6379"
REDIS_PASSWORD=redis_secret

# NextAuth.js

# Google SSO (required for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-chars-long"

# AWS S3 / MinIO (local dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin123"
S3_BUCKET="complianceai-recordings"
S3_TRANSCRIPTS_BUCKET="complianceai-transcripts"

# MinIO (for docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Five9 Integration
FIVE9_USERNAME="your-five9-username"
FIVE9_PASSWORD="your-five9-password"
FIVE9_DOMAIN_ID="your-domain-id"

# Five9 S3 Bucket (where Five9 stores recordings)
FIVE9_S3_BUCKET="your-five9-recordings-bucket"
FIVE9_S3_REGION="us-east-1"
FIVE9_S3_ACCESS_KEY="your-five9-s3-access-key"
FIVE9_S3_SECRET_KEY="your-five9-s3-secret-key"

# Notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
NOTIFICATION_EMAIL="compliance@company.com"

# SMTP (for email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Encryption (AES-256 key - must be exactly 32 bytes)
ENCRYPTION_KEY="your-32-byte-encryption-key-here!!"
