{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/worker",
    "rootDir": ".",
    "noEmit": false,
    "target": "ES2020",
    "lib": ["ES2020"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "worker/**/*",
    "lib/**/*",
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules",
    "app/**/*",
    "components/**/*",
    ".next/**/*"
  ]
}
